# Copy this file to .env and fill in your values

# --- Embeddings ---
# "local" (free, runs offline) or "openai" (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=local

# --- LLM ---
# Provider used by the agents: "deepseek" | "openai" | "anthropic"
LLM_PROVIDER=deepseek
# Model name. Examples: deepseek-chat, deepseek-reasoner, gpt-4o-mini, gpt-4o,
# claude-3-5-sonnet-latest
LLM_MODEL=deepseek-chat

# When MOCK_LLM=true, agents return fixture responses instead of calling the real API.
# Lets you run the whole app offline. Flip to false to use the real API.
MOCK_LLM=true

# --- API keys (only used when MOCK_LLM=false) ---
# Required if LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Required if LLM_PROVIDER=openai (and/or EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional override for OpenAI-compatible endpoints. Leave empty for defaults.
# (DeepSeek is auto-routed to https://api.deepseek.com — no need to set this.)
LLM_BASE_URL=

# --- Notes ---
# - Copy this file to .env and edit values there.
# - If MOCK_LLM is set in your PowerShell session, it overrides this file.
#   Example: $env:MOCK_LLM = "false" before streamlit run
# - Python 3.11+ recommended (tested on 3.13).
