# Copy this file to .env and fill in your values

# Embeddings provider: "local" (free, runs offline) or "openai" (requires key)
EMBEDDING_PROVIDER=local

# LLM provider: "openai" or "anthropic" (only needed when running the agents)
LLM_PROVIDER=openai

# Only required if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Only required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
